# MongoDB Runtime Configuration
MONGO_URI=mongodb://mongodb:27017
MONGO_DB_NAME=insta_app

# Legacy MySQL Source (optional, only for migrate_mysql_to_mongo.php)
LEGACY_MYSQL_HOST=127.0.0.1
LEGACY_MYSQL_PORT=3306
LEGACY_MYSQL_DB=insta_app
LEGACY_MYSQL_USER=root
LEGACY_MYSQL_PASS=root

# JWT Configuration
JWT_SECRET=supersecretkey123

# Application Settings
APP_ENV=development
BASE_URL=http://localhost:8080

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# S3/MinIO Configuration
S3_ENDPOINT=http://minio:9000
S3_KEY=minioadmin
S3_SECRET=minioadmin
S3_BUCKET=insta-media
S3_REGION=us-east-1
USE_S3=false

# Google OAuth Configuration
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project
# 3. Enable Google+ API
# 4. Create OAuth 2.0 credentials (Web application)
# 5. Add authorized redirect URI: http://localhost:8080/api/auth/google-callback
# 6. Copy your Client ID and Client Secret below

GOOGLE_CLIENT_ID=test_client_id_123456789.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX_test_secret_1234567890
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google-callback
