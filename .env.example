# MongoDB Runtime Configuration
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB_NAME=insta_app

# Legacy MySQL Source (optional, only for database/migrate_mysql_to_mongo.php)
# Example for XAMPP defaults:
LEGACY_MYSQL_HOST=127.0.0.1
LEGACY_MYSQL_PORT=3306
LEGACY_MYSQL_DB=insta_app
LEGACY_MYSQL_USER=root
LEGACY_MYSQL_PASS=

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production_1234567890

# Application Settings
APP_ENV=development
BASE_URL=http://localhost:8080

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# S3/MinIO Configuration
S3_ENDPOINT=http://localhost:9000
S3_KEY=minioadmin
S3_SECRET=minioadmin
S3_BUCKET=insta-media
S3_REGION=us-east-1
USE_S3=false

# Google OAuth Configuration
# Get these from https://console.cloud.google.com/
# Create OAuth 2.0 credentials and authorize redirect URI: http://localhost:8080/api/auth/google-callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google-callback
